{
  "name": "cofo-indicators",
  "version": "1.0.0",
  "description": "A TypeScript library for technical indicators, OHLCV data handling, and number formatting utilities.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "prettier:format": "prettier --write './src/**/*.{js,jsx,ts,tsx,json}' --config .prettierrc",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prepare": "husky",
    "prepublishOnly": "npm run prettier:format && npm run lint && npm run test"
  },
  "keywords": [
    "trading",
    "indicators",
    "technical-analysis",
    "finance"
  ],
  "author": "Collective Forecast",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/jest": "^29.5.14",
    "eslint": "^9.36.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "jiti": "^2.6.0",
    "lint-staged": "^16.2.1",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  },
  "lint-staged": {
    "./src/**/*.{js,ts}": [
      "npm run prettier:format",
      "npm run lint",
      "npm run test"
    ]
  }
}
